# Скопируй этот файл в .env и впиши свои значения
# .env в git НЕ попадёт (занесён в .gitignore)

BOT_TOKEN=
ADMIN_USER_ID=

# URL твоего ngrok-туннеля (запусти: ngrok http 8000)
WEBAPP_URL=https://your-ngrok-url.ngrok-free.app

# Оценка ответов через ИИ (платно, через OpenAI). По умолчанию выкл.
USE_AI_GRADING=false
OPENAI_API_KEY=
